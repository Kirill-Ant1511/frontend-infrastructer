{
  // Настройки для компилятора TypeScript
  "compilerOptions": {
    // Указываем, что хотим компилировать в ES5 для лучшей совместимости с браузерами
    "target": "es5",
    // Определяет, какие библиотеки типов файлов должны быть подключены к проекту.
    "lib": ["dom", "dom.iterable", "esnext"],
    // Разрешает импортировать файлы .js в проект TypeScript.
    "allowJs": true,
    // Пропускает проверку типов в файлах деклараций (.d.ts).
    "skipLibCheck": true,
    // Упрощает взаимодействие между модулями ES6 и CommonJS.
    "esModuleInterop": true,
    // Разрешает импорты по умолчанию из модулей, у которых явно не указано экспорта по умолчанию.
    "allowSyntheticDefaultImports": true,
    // Включает строгую проверку типов, что помогает выявлять потенциальные ошибки в коде.
    "strict": true,
    // Гарантирует, что имена файлов в импортах совпадают с реальными именами файлов на диске, что предотвращает проблемы с регистром в разных операционных системах.
    "forceConsistentCasingInFileNames": true,
    // Указывает, что компилятор должен использовать модульную систему ESNext, которая поддерживает динамические импорты и другие современные возможности модулей.
    "module": "esnext",
    // Указывает, что компилятор должен использовать алгоритм разрешения модулей Node.js, который позволяет импортировать модули из папки node_modules и поддерживает расширения файлов .js и .jsx.
    "moduleResolution": "node",
    // Разрешает импортировать файлы JSON как модули, что позволяет использовать данные из JSON-файлов в коде TypeScript.
    "resolveJsonModule": true,
    // Включает поддержку JSX, что позволяет использовать синтаксис JSX для описания пользовательского интерфейса в файлах с расширением .tsx.
    "isolatedModules": true,
    // Указывает, что компилятор не должен генерировать выходные файлы JavaScript, а только проверять типы в коде TypeScript
    "noEmit": true,
    // Указывает, что компилятор должен использовать новый трансформер JSX, который поддерживает автоматический импорт React в файлах с JSX-синтаксисом.
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
